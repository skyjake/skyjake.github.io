{"repo": {"timestamp": 1774635788000, "categories": {"fdroid": null, "Internet": {"name": {"en-US": "Internet"}}}}, "packages": {"fi.skyjake.lagrange": {"metadata": {"added": 1773214964000, "categories": ["Internet"], "issueTracker": "https://github.com/skyjake/lagrange/issues", "lastUpdated": 1774635788000, "sourceCode": "https://github.com/skyjake/lagrange/", "webSite": "https://gmi.skyjake.fi/lagrange/", "authorName": "Jaakko Keränen", "summary": {"en-US": "Smallnet Browser"}, "description": {"en-US": "A beautiful Gemini client and a browser for many other smallnet protocols.\n\nBeyond the World Wide Web, there is a frontier of hobbyist network protocols that aim to restore a more human-centric ethos to the internet. This is called the \"small internet\", or smallnet. Lagrange supports many of these protocols and lets you explore smallnet sites while enjoying modern conveniences familiar from web browsers, like beautiful typography, inline image viewing, multiple tabs, visual themes, bookmarks, history, and page outlines.\n"}, "icon": {"en-US": {"name": "/fi.skyjake.lagrange/en-US/icon_tU-iYbvLqk1K7ZzFbcA4Te7xmbcR2LEo7dOc5HdM0WA=.png", "sha256": "b54fa261bbcbaa4d4aed9cc56dc0384deef199b711d8b128edd39ce4774cd160", "size": 142174}}}, "versions": {"49774be05a13fa93f56f12d10cc641e76c24eb44f4aa50a65894bbc6925353e7": null, "cd28ca8fc08861a4d0624ec8ac4b8a876679bfa9cdac0efa23e1af4fda09215d": null, "bfba125d21e0d8dc7d60218a2a1d7ebe1749d43212f55dfc5944add401580d7b": {"added": 1774635788000, "file": {"name": "/lagrange_v1.20b50_phone.apk", "sha256": "bfba125d21e0d8dc7d60218a2a1d7ebe1749d43212f55dfc5944add401580d7b", "size": 22094925}, "manifest": {"nativecode": ["arm64-v8a", "armeabi-v7a", "x86", "x86_64"], "versionName": "1.20b50", "versionCode": 12004, "usesSdk": {"minSdkVersion": 19, "targetSdkVersion": 36}, "signer": {"sha256": ["3b08e8b0eb893313a38a16a93195ce68ce4f7104757950999ef5f4f1257804aa"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "andr